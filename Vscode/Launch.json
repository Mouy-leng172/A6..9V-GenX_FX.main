{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Jules Bot",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/jules/main.py",
      "console": "integratedTerminal",
      "env": {
        "JULES_MODE": "trading",
        "JULES_CONFIG": "${workspaceFolder}/config/trading.json"
      }
    },
    {
      "name": "Debug Jules Task Scheduler",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/jules/scheduler.js",
      "cwd": "${workspaceFolder}"
    }
  ]
}
