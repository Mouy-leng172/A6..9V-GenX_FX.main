<component name="ProjectRunConfigurationManager">
  <configuration default="false" name="Run Jules Bot (Local)" type="PythonConfigurationType" factoryName="Python">
    <module name="jules" />
    <option name="SCRIPT_NAME" value="$PROJECT_DIR$/jules/main.py" />
    <option name="WORKING_DIRECTORY" value="$PROJECT_DIR$" />
    <envs>
      <env name="JULES_MODE" value="trading" />
      <env name="JULES_CONFIG" value="$PROJECT_DIR$/config/trading.json" />
    </envs>
    <option name="PARAMETERS" value="" />
    <option name="INTERPRETER_OPTIONS" value="" />
    <option name="SDK_HOME" value="" />
  </configuration>

  <configuration default="false" name="Debug Jules Scheduler (Local)" type="NodeJSConfigurationType" factoryName="Node.js">
    <module name="jules" />
    <option name="WORKING_DIRECTORY" value="$PROJECT_DIR$/jules" />
    <option name="NODE_PARAMETERS" value="" />
    <option name="WORKING_DIRECTORY" value="$PROJECT_DIR$" />
    <option name="SCRIPT_NAME" value="$PROJECT_DIR$/jules/scheduler.js" />
  </configuration>

  <configuration default="false" name="Launch Jules in Docker" type="DockerDeploymentConfigurationType" factoryName="Docker">
    <deployment>
      <option name="imageId" value="jules:latest" />
      <option name="containerName" value="jules-container" />
      <option name="command" value="python /usr/src/app/main.py" />
      <envs>
        <env name="JULES_MODE" value="trading" />
        <env name="JULES_CONFIG" value="/usr/src/app/config/trading.json" />
      </envs>
    </deployment>
  </configuration>

  <configuration default="false" name="Run All Agents" type="NodeJSConfigurationType" factoryName="Node.js">
    <module name="agents" />
    <option name="WORKING_DIRECTORY" value="$PROJECT_DIR$/agents" />
    <option name="SCRIPT_NAME" value="$PROJECT_DIR$/agents/orchestrator.js" />
  </configuration>
</component>
